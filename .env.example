# AlphOne configuration. Copy to .env and fill in the values.
# Real environment variables take precedence over anything set here.

ALPHONE_DATABASE_URL=postgres://postgres:alphone@localhost:5433/postgres?sslmode=disable
# ALPHONE_ADDR=localhost:8080

# Comma-separated CIDR ranges of reverse proxies allowed for login rate limiting.
# ALPHONE_TRUSTED_PROXIES=10.0.0.0/8

# WhatsApp plugin — Meta WhatsApp Cloud API credentials.
ALPHONE_WHATSAPP_VERIFY_TOKEN=
ALPHONE_WHATSAPP_APP_SECRET=
ALPHONE_WHATSAPP_ACCESS_TOKEN=
ALPHONE_WHATSAPP_PHONE_NUMBER_ID=
